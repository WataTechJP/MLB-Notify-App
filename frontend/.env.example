# バックエンドAPIのベースURL
# ローカル開発: http://localhost:8001
# 本番: https://your-production-domain.com
EXPO_PUBLIC_API_BASE_URL=https://mlb-notify-app-production.up.railway.app

# Expo Push Token取得に必要な EAS Project ID
# Expo Dashboard > Project > Project ID (UUID) を設定
EXPO_PUBLIC_EAS_PROJECT_ID=

# 本番ビルドで通知テストUIを出したい時だけ true
EXPO_PUBLIC_ENABLE_TEST_TOOLS=false
